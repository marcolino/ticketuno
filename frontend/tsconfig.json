{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    //"baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"], // Override path for frontend
      "@ticketuno/shared": ["../packages/shared/src/index.ts"],
      "@ticketuno/shared/*": ["../packages/shared/src/*"]
    }
  },

  "include": [
    "src",
    "../packages/shared/src"
  ]
}
