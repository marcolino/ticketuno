{
  "name": "ticketuno",
  "version": "1.0.0",
  "description": "Theater ticket reservation system",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run start",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test -- --watchAll=false",
    "UNUSED-setup:fly": "./scripts/setup-fly.sh",
    "deploy": "./scripts/deploy.sh",
    "UNUSED-dep": "npm run build && ./scripts/deploy.sh",
    "logs": "fly logs --app ticketuno",
    "status": "fly status --app ticketuno",
    "ssh": "fly ssh console --app ticketuno",
    "db:backup": "fly ssh console --app ticketuno -C 'cat /data/theaters.db' > backup-$(date +%Y%m%d-%H%M%S).db"
  },
  "keywords": [
    "theater",
    "tickets",
    "reservation"
  ],
  "author": "Marco Solari <marcosolari@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "react-hot-toast": "^2.6.0"
  }
}
