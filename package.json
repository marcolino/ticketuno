{
  "name": "ticketuno",
  "version": "1.0.0",
  "description": "Theater ticket reservation system",
  "private": true,
  "keywords": [
    "theater",
    "tickets",
    "reservation"
  ],
  "author": "Marco Solari <marcosolari@gmail.com]",
  "license": "MIT",
  "scripts": {
    "validate": "npm run check:frontend && npm run check:backend && npm run unused",
    "bump:major": "npm version major",
    "bump:minor": "npm version minor",
    "bump:patch": "npm version patch",
    "release": "npm run validate && npm run bump:patch",
    "run-build-version": "cd frontend && npm run build && npm run preview",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "check": "npm run check:frontend && npm run check:backend",
    "check:frontend": "cd frontend && npm run check",
    "check:backend": "cd backend && npm run check",
    "unused": "npm run unused:frontend && npm run unused:backend",
    "unused:frontend": "cd frontend && npm run unused",
    "unused-backend": "cd backend && npm run unused",
    "type-check": "npm run type-check:backend && npm run type-check:frontend",
    "type-check:backend": "cd backend && npx tsc --noEmit || echo 'Backend TypeScript check skipped'",
    "type-check:frontend": "cd frontend && npx tsc --noEmit || echo 'Frontend TypeScript check skipped'",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test -- --watchAll=false",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "i18n:extract": "scripts/extract-mjml-keys.js && i18next-cli extract --config i18next.config.js",
    "i18n:extract:watch": "i18next-cli extract --watch --config i18next.config.js",
    "i18n:sync": "i18next-cli sync --config i18next.config.js",
    "i18n:types": "i18next-cli types --config i18next.config.js",
    "i18n:status": "i18next-cli status --verbose --config i18next.config.js",
    "i18n:all": "npm run i18n:extract && npm run i18n:sync && npm run i18n:types",
    "i18n:auto": "npx i18n-auto-translation --from en --to it,fr --filePath ./shared/locales/en/translation.json",
    "maintenance-set": "fly secrets set MAINTENANCE_MODE=1 -a ticketuno",
    "maintenance-reset": "fly secrets set MAINTENANCE_MODE=0 -a ticketuno",
    "maintenance-print": "fly ssh console -a ticketuno -C \"printenv MAINTENANCE_MODE\"",
    "deploy": "./scripts/deploy.sh && npm run play-ok || npm run play-ko",
    "logs": "fly logs --app ticketuno",
    "status": "fly status --app ticketuno",
    "ssh": "fly ssh console --app ticketuno",
    "db:backup": "fly ssh console --app ticketuno -C 'cat /data/ticketuno.db' > backup-$(date +%Y%m%d-%H%M%S).db",
    "play-ok": "date; ffplay -loglevel 0 -autoexit -nodisp dev/sounds/trumpet.wav",
    "play-ko": "date; ffplay -loglevel 0 -autoexit -nodisp dev/sounds/finish.wav"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "i18n-auto-translation": "^1.0.1",
    "i18next-cli": "^1.34.1"
  },
  "dependencies": {
    "react-hot-toast": "^2.6.0"
  },
  "NOpackageManager_TODO_REMOVEME": "yarn@4.6.0+sha512.5383cc12567a95f1d668fbe762dfe0075c595b4bfff433be478dbbe24e05251a8e8c3eb992a986667c1d53b6c3a9c85b8398c35a960587fbd9fa3a0915406728",
  "packageManager": "yarn@4.6.0+sha512.5383cc12567a95f1d668fbe762dfe0075c595b4bfff433be478dbbe24e05251a8e8c3eb992a986667c1d53b6c3a9c85b8398c35a960587fbd9fa3a0915406728"
}
