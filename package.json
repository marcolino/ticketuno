{
  "name": "ticketuno",
  "version": "1.0.0",
  "private": true,
  "description": "Theater ticket reservation system",
  "author": "Marco Solari <marcosolari@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace frontend run dev\" \"npm --workspace backend run dev\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "npm --workspace @ticketuno/shared run build",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "postinstall": "npm run build --workspace=packages/shared",
    "type-check": "npm run type-check:shared && npm run type-check:backend && npm run type-check:frontend",
    "type-check:shared": "npm --workspace @ticketuno/shared run type-check",
    "type-check:backend": "npm --workspace backend run type-check",
    "type-check:frontend": "npm --workspace frontend run type-check",
    "check": "npm run check:frontend && npm run check:backend",
    "check:frontend": "npm --workspace frontend run check",
    "check:backend": "npm --workspace backend run check",
    "unused": "npm run unused:frontend && npm run unused:backend",
    "unused:frontend": "npm --workspace frontend run unused",
    "unused:backend": "npm --workspace backend run unused",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm --workspace backend run test",
    "test:frontend": "npm --workspace frontend run test",
    "validate": "npm run type-check && npm run check && npm run unused",
    "install:all": "npm install",
    "bump:major": "npm version major",
    "bump:minor": "npm version minor",
    "bump:patch": "npm version patch",
    "pwa:generate": "./scripts/generate-pwa-assets.js",
    "i18n:extract": "./scripts/extract-mjml-keys.js && i18next-cli extract --config i18next.config.js",
    "i18n:extract:watch": "i18next-cli extract --watch --config i18next.config.js",
    "i18n:sync": "i18next-cli sync --config i18next.config.js",
    "i18n:types": "i18next-cli types --config i18next.config.js",
    "i18n:status": "scripts/missing-translations.sh",
    "i18n:auto": "./scripts/translate.js",
    "i18n:all": "npm run i18n:extract && npm run i18n:sync && npm run i18n:auto",
    "deploy:staging": "./scripts/deploy.sh --staging && npm run play-ok || npm run play-ko",
    "deploy:prod": "./scripts/deploy.sh --force && npm run play-ok || npm run play-ko",
    "maintenance-set": "fly secrets set MAINTENANCE_MODE=1 -a ticketuno",
    "maintenance-reset": "fly secrets set MAINTENANCE_MODE=0 -a ticketuno",
    "maintenance-set:staging": "fly secrets set MAINTENANCE_MODE=1 -a ticketuno-staging",
    "maintenance-reset:staging": "fly secrets set MAINTENANCE_MODE=0 -a ticketuno-staging",
    "logs": "fly logs --app ticketuno",
    "status": "fly status --app ticketuno",
    "ssh": "fly ssh console --app ticketuno",
    "db:edit": "./scripts/db-edit.sh",
    "db:backup": "fly ssh console --app ticketuno -C 'cat /data/ticketuno.db' > backup-$(date +%Y%m%d-%H%M%S).db",
    "db:destroy": "scripts/db-destroy.sh",
    "detached-volumes:destroy": "fly volumes list --json | jq -r '.[] | select(.attached_machine_id == null or .attached_machine_id == \"\") | .id' | xargs -I {} fly volumes delete --yes {}",
    "web-push-generate-vapid-keys": "npx web-push generate-vapid-keys",
    "check-git-leaks": "gitleaks detect --source . --log-opts='--all' -v",
    "archive": "scripts/archive-temporary-files.sh",
    "play-ok": "date; ffplay -loglevel 0 -autoexit -nodisp dev/sounds/trumpet.wav",
    "play-ko": "date; ffplay -loglevel 0 -autoexit -nodisp dev/sounds/finish.wav",
    "ngrok": "ngrok http --url=cockatoo-liberal-eft.ngrok-free.app 3000 > /dev/null 2>&1 &"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.15.0",
    "i18next-cli": "^1.34.1",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "i18next": "^25.8.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "bcrypt@5.1.1": true,
    "sqlite3@5.1.7": true,
    "@swc/core@1.15.43": true
  },
  "packageManager": "yarn@4.6.0+sha512.5383cc12567a95f1d668fbe762dfe0075c595b4bfff433be478dbbe24e05251a8e8c3eb992a986667c1d53b6c3a9c85b8398c35a960587fbd9fa3a0915406728"
}
