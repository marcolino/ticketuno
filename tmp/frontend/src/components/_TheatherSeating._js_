import React, { useState } from 'react';
import { Users, Check, X } from 'lucide-react';

const TheaterSeating = () => {
  // Sample theater layout - in production, this would come from your backend
  const theaterLayout = {
    name: "Main Theater",
    sections: [
      {
        name: "Orchestra",
        rows: [
          { id: "A", seats: 12, startNumber: 1 },
          { id: "B", seats: 14, startNumber: 1 },
          { id: "C", seats: 14, startNumber: 1 },
          { id: "D", seats: 16, startNumber: 1 },
          { id: "E", seats: 16, startNumber: 1 },
        ]
      },
      {
        name: "Mezzanine",
        rows: [
          { id: "F", seats: 10, startNumber: 1 },
          { id: "G", seats: 10, startNumber: 1 },
          { id: "H", seats: 12, startNumber: 1 },
        ]
      }
    ]
  };

  // Simulated already-booked seats
  const [bookedSeats] = useState(new Set([
    "A-3", "A-4", "B-7", "B-8", "C-5", "D-9", "D-10", "F-4", "F-5", "H-6"
  ]));

  const [selectedSeats, setSelectedSeats] = useState(new Set());
  const [showConfirmation, setShowConfirmation] = useState(false);

  const toggleSeat = (seatId) => {
    if (bookedSeats.has(seatId)) return;
    
    const newSelected = new Set(selectedSeats);
    if (newSelected.has(seatId)) {
      newSelected.delete(seatId);
    } else {
      newSelected.add(seatId);
    }
    setSelectedSeats(newSelected);
  };

  const getSeatStatus = (seatId) => {
    if (bookedSeats.has(seatId)) return 'booked';
    if (selectedSeats.has(seatId)) return 'selected';
    return 'available';
  };

  const handleBooking = () => {
    setShowConfirmation(true);
  };

  const confirmBooking = () => {
    // In production, send booking to backend
    alert(`Successfully booked ${selectedSeats.size} seat(s): ${Array.from(selectedSeats).join(', ')}`);
    setSelectedSeats(new Set());
    setShowConfirmation(false);
  };

  const totalPrice = selectedSeats.size * 45; // $45 per seat

  return (
    <div className="min-h-screen bg-gradient-to-br from-purple-900 via-purple-800 to-indigo-900 p-8">
      <div className="max-w-6xl mx-auto">
        <div className="bg-white rounded-lg shadow-2xl p-8">
          <h1 className="text-3xl font-bold text-gray-800 mb-2">{theaterLayout.name}</h1>
          <p className="text-gray-600 mb-6">Select your seats to continue</p>

          {/* Stage */}
          <div className="mb-12">
            <div className="bg-gradient-to-b from-amber-400 to-amber-500 rounded-t-full h-16 flex items-center justify-center shadow-lg">
              <span className="text-amber-900 font-semibold text-lg">STAGE</span>
            </div>
          </div>

          {/* Seating sections */}
          {theaterLayout.sections.map((section, sectionIdx) => (
            <div key={sectionIdx} className="mb-8">
              <h2 className="text-xl font-semibold text-gray-700 mb-4 text-center">
                {section.name}
              </h2>
              <div className="space-y-3">
                {section.rows.map((row) => (
                  <div key={row.id} className="flex items-center justify-center gap-2">
                    <span className="w-8 text-center font-semibold text-gray-600">
                      {row.id}
                    </span>
                    <div className="flex gap-2">
                      {Array.from({ length: row.seats }, (_, i) => {
                        const seatNumber = row.startNumber + i;
                        const seatId = `${row.id}-${seatNumber}`;
                        const status = getSeatStatus(seatId);
                        
                        return (
                          <button
                            key={seatId}
                            onClick={() => toggleSeat(seatId)}
                            disabled={status === 'booked'}
                            className={`
                              w-10 h-10 rounded-lg font-medium text-sm transition-all duration-200
                              ${status === 'available' 
                                ? 'bg-green-100 text-green-700 hover:bg-green-200 hover:scale-110' 
                                : status === 'selected'
                                ? 'bg-blue-500 text-white scale-110 shadow-lg'
                                : 'bg-gray-300 text-gray-500 cursor-not-allowed'
                              }
                            `}
                            title={`${row.id}-${seatNumber} (${status})`}
                          >
                            {seatNumber}
                          </button>
                        );
                      })}
                    </div>
                    <span className="w-8 text-center font-semibold text-gray-600">
                      {row.id}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))}

          {/* Legend */}
          <div className="flex justify-center gap-8 mt-8 p-4 bg-gray-50 rounded-lg">
            <div className="flex items-center gap-2">
              <div className="w-8 h-8 bg-green-100 border-2 border-green-300 rounded-lg"></div>
              <span className="text-gray-700">Available</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-8 h-8 bg-blue-500 rounded-lg"></div>
              <span className="text-gray-700">Selected</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-8 h-8 bg-gray-300 rounded-lg"></div>
              <span className="text-gray-700">Booked</span>
            </div>
          </div>

          {/* Booking summary */}
          {selectedSeats.size > 0 && (
            <div className="mt-8 p-6 bg-blue-50 border-2 border-blue-200 rounded-lg">
              <div className="flex items-center justify-between mb-4">
                <div className="flex items-center gap-2">
                  <Users className="text-blue-600" />
                  <span className="font-semibold text-gray-800">
                    {selectedSeats.size} seat{selectedSeats.size > 1 ? 's' : ''} selected
                  </span>
                </div>
                <span className="text-2xl font-bold text-gray-800">
                  ${totalPrice}
                </span>
              </div>
              <div className="mb-4 text-gray-600">
                <strong>Seats:</strong> {Array.from(selectedSeats).join(', ')}
              </div>
              <button
                onClick={handleBooking}
                className="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors"
              >
                Proceed to Checkout
              </button>
            </div>
          )}
        </div>
      </div>

      {/* Confirmation Modal */}
      {showConfirmation && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
          <div className="bg-white rounded-lg p-8 max-w-md w-full shadow-2xl">
            <h2 className="text-2xl font-bold text-gray-800 mb-4">Confirm Booking</h2>
            <p className="text-gray-600 mb-2">
              You are about to book <strong>{selectedSeats.size}</strong> seat(s):
            </p>
            <div className="bg-gray-50 p-4 rounded-lg mb-4">
              <p className="font-semibold text-gray-800">
                {Array.from(selectedSeats).join(', ')}
              </p>
            </div>
            <div className="text-xl font-bold text-gray-800 mb-6">
              Total: ${totalPrice}
            </div>
            <div className="flex gap-4">
              <button
                onClick={confirmBooking}
                className="flex-1 bg-green-600 text-white py-3 rounded-lg font-semibold hover:bg-green-700 transition-colors flex items-center justify-center gap-2"
              >
                <Check size={20} />
                Confirm
              </button>
              <button
                onClick={() => setShowConfirmation(false)}
                className="flex-1 bg-gray-300 text-gray-700 py-3 rounded-lg font-semibold hover:bg-gray-400 transition-colors flex items-center justify-center gap-2"
              >
                <X size={20} />
                Cancel
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default TheaterSeating;