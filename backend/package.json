{
  "name": "ticketuno-backend",
  "version": "1.0.1",
  "description": "Theater ticket reservation system, backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development PORT=3001 ts-node-dev --respawn src/server.ts",
    "start": "NODE_ENV=development PORT=3001 node dist/server.js",
    "lint": "eslint src",
    "test": "vitest run",
    "migrations": "mkdir -p dist/db/migrations && cp -r src/db/migrations/* dist/db/migrations/",
    "build": "tsc && npm run migrations",
    "patch": "npm version patch",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run test"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "google-auth-library": "^10.5.0",
    "i18next": "^25.7.4",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "sqlite3": "^5.1.7",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.30",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
