{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@ticketuno/shared": ["../packages/shared/src/index.ts"],
      "@ticketuno/shared/*": ["../packages/shared/src/*"]
    }
  },

  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../packages/shared/node_modules"
  ]
}
