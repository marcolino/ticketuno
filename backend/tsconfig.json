{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    //"lib": ["ES2021", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    // "allowJs": true,
    // "checkJs": false,
    "noImplicitAny": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/shared/types/dialog.ts", // Exclude frontend only types
  ],
}