BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
JWT_SECRET=secret-key-change-this-in-production
ADMIN_USER_EMAIL=admin@mail.com
ADMIN_USER_PASSWORD=password
OPERATOR_USER_EMAIL=operator@mail.com
OPERATOR_USER_PASSWORD=password
EMAIL_TOKEN_SECRET=your-token-secret-for-email-unsubscribe
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
RESEND_API_KEY=your-resend-api-key
GIT_COMMIT=$(git rev-parse --short HEAD)
GIT_COMMIT_DATE=$(git log -1 --format='%ci' | cut -c1-19)
MAINTENANCE_MODE=0
